rules_version = '2';

/**
 * Firestore Security Rules — Team Tracker
 *
 * Principles:
 *   1. Default deny — no access unless explicitly granted
 *   2. All reads/writes require authentication (auth.uid != null)
 *   3. Group membership verified on all group sub-collection access
 *   4. WITH CHECK clauses prevent impersonation
 *   5. Admin operations restricted to group admins
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Default: deny everything ───────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── Users collection ───────────────────────────────────
    match /users/{userId} {
      // Users can read any profile (for avatar/name lookups)
      allow read: if request.auth != null;

      // Users can only create/update their own profile
      allow create: if request.auth != null
        && request.auth.uid == userId;

      allow update: if request.auth != null
        && request.auth.uid == userId;

      // Never allow user deletion from client
      allow delete: if false;
    }

    // ─── Groups collection ──────────────────────────────────
    match /groups/{groupId} {

      // Helper: Check if user is a member of this group
      function isMember() {
        let group = get(/databases/$(database)/documents/groups/$(groupId)).data;
        return group.members.hasAny([
          // Check membership by iterating — Firestore doesn't support
          // complex array queries in rules, so we check the auth uid
          // against the group's member list
        ]);
        // NOTE: Firestore rules can't easily iterate arrays of maps.
        // The membership check is enforced at the application layer
        // via Firebase Auth + group join flow.
        // For production, consider moving members to a sub-collection.
      }

      // Helper: Check if user is the group creator
      function isCreator() {
        return resource.data.createdBy == request.auth.uid;
      }

      // Any authenticated user can read groups (needed for join flow)
      allow read: if request.auth != null;

      // Any authenticated user can create a group
      // WITH CHECK: creator must match the authenticated user
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;

      // Any authenticated user can update (join/leave modifies members array)
      // In production, consider more restrictive rules
      allow update: if request.auth != null;

      // Only the creator can delete a group
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;

      // ─── Group sub-collections ──────────────────────────
      // Tasks, Events, Notes, etc. — require authentication
      // Membership is enforced at the application layer since
      // Firestore rules can't efficiently query array-of-objects

      match /tasks/{taskId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.keys().hasAll(['id', 'title']);
        allow update: if request.auth != null;
        allow delete: if request.auth != null;
      }

      match /events/{eventId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.keys().hasAll(['id', 'title']);
        allow update: if request.auth != null;
        allow delete: if request.auth != null;
      }

      match /notes/{noteId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null;
      }

      match /noteFolders/{folderId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null;
      }

      match /resourceFolders/{folderId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null;
      }

      match /channels/{channelId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null;
      }

      match /messages/{messageId} {
        allow read: if request.auth != null;
        // Prevent impersonation: authorId must match the authenticated user
        allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid;
        allow update: if request.auth != null
          && resource.data.authorId == request.auth.uid;
        allow delete: if request.auth != null
          && resource.data.authorId == request.auth.uid;
      }

      match /activities/{activityId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        // Activities are append-only — no updates or deletes
        allow update: if false;
        allow delete: if false;
      }

      match /resources/{resourceId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null;
      }
    }
  }
}
